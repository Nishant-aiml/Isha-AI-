<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FEF2F2"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🚨 Failsafe Recovery Console"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#991B1B"
        android:gravity="center"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This console runs in an isolated process to allow manual state recovery during GGUF corruption, JNI segfaults, or severe LMK loops."
        android:textColor="#7F1D1D"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnWipeCache"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear Temporary Cache"
        android:backgroundTint="#DC2626"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnDeleteModels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Model GGUF Weights"
        android:backgroundTint="#B91C1C"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnVerifyStorage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Query Free Internal Storage"
        android:backgroundTint="#4B5563"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/txtRecoveryLog"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:text="Ready for maintenance tasks..."
        android:textColor="#1F2937"
        android:elevation="1dp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnExitRecovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exit &amp; Restart App"
        android:backgroundTint="#059669"
        android:textColor="#FFFFFF"/>

</LinearLayout>
